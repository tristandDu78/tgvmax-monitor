# ── Discord ──────────────────────────────────────────────────────────────────
# Portail développeur : https://discord.com/developers/applications

# ID de votre application Discord (onglet "OAuth2")
DISCORD_CLIENT_ID=123456789012345678

# Secret OAuth2 (onglet "OAuth2" > "Client Secret")
DISCORD_CLIENT_SECRET=AbCdEfGhIjKlMnOpQrStUvWxYz012345

# Token du bot (onglet "Bot" > "Token")
DISCORD_BOT_TOKEN=MTE...votre_token_bot...

# ID du serveur Discord de notification (clic droit sur le serveur > "Copier l'identifiant")
# Nécessite le mode Développeur Discord activé (Paramètres > Avancé > Mode développeur)
DISCORD_GUILD_ID=987654321098765432

# ── Base de données Supabase ──────────────────────────────────────────────────
# Tableau de bord Supabase > Paramètres > API

# URL du projet (ex : https://abcdefgh.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé "service_role" (PAS la clé anon — onglet API > service_role)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Application ───────────────────────────────────────────────────────────────
# URL publique de votre app (sans slash final)
# Sur Render, c'est automatiquement https://<nom-service>.onrender.com
APP_URL=https://tgvmax-monitor.onrender.com

# Intervalle de vérification en minutes (défaut : 30)
CHECK_INTERVAL_MINUTES=30
